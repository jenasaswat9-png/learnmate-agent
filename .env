# ==============================================================================
# LearnMate AI Agent - Environment Configuration Template
# ==============================================================================
# INSTRUCTIONS:
# 1. Copy this file and rename it to exactly: .env
# 2. Replace the placeholder values below with your actual IBM credentials.
# 3. NEVER commit your real .env file to GitHub!
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. IBM Cloud API Key
# ------------------------------------------------------------------------------
# Required to authenticate your application with IBM Cloud services.
# Where to find it: IBM Cloud Console -> Manage -> Access (IAM) -> API Keys
IBM_API_KEY=your_ibm_cloud_api_key_here

# ------------------------------------------------------------------------------
# 2. Watsonx Project ID
# ------------------------------------------------------------------------------
# The specific UUID of the Watsonx project where your models are hosted.
# Where to find it: Watsonx.ai Dashboard -> Select Project -> Manage -> General
IBM_PROJECT_ID=your_watsonx_project_id_here

# ------------------------------------------------------------------------------
# 3. IBM Machine Learning Endpoint URL
# ------------------------------------------------------------------------------
# The regional cloud endpoint where your specific Watsonx instance lives.
# Note: If your IBM project is in Dallas, use https://us-south.ml.cloud.ibm.com
# The default for this specific build is Sydney.
IBM_URL=your_ibm_url
